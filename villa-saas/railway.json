{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/backend/**",
      "packages/**"
    ]
  },
  "deploy": {
    "startCommand": "cd apps/backend && npm run build && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}